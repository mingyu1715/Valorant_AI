{
  "name": "valorant-ai-tactical-coach",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:mock": "npm run mode:mock && npm run dev",
    "dev:production": "npm run mode:production && npm run dev",
    "prebuild": "npm run db:generate",
    "build": "next build --webpack",
    "start": "node scripts/start.mjs",
    "security:check": "node scripts/security-check.mjs",
    "mode:mock": "node scripts/runtime-mode.mjs mock",
    "mode:production": "node scripts/runtime-mode.mjs production",
    "mode:status": "node scripts/runtime-mode.mjs status",
    "test:llm:mock": "node --no-warnings scripts/test-llm-sample.mjs",
    "test:llm:real": "node --no-warnings scripts/test-llm-real.mjs",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
